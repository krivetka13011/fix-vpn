# Telegram-Hub: командные боты FIX VPN
# ⚠️ Этот файл — ШАБЛОН. Замените значения на реальные и переименуйте в .env
# ⚠️ .env находится в .gitignore — НИКОГДА НЕ КОММИТИТЬ

# Получить токены: @BotFather → /newbot (один бот на роль)
DESIGNER_BOT_TOKEN=123456789:AAA...
DEVELOPER_BOT_TOKEN=123456789:AAA...
TESTER_BOT_TOKEN=123456789:AAA...
ADMIN_BOT_TOKEN=123456789:AAA...

# ID группового чата команды (отрицательное число)
# Узнать: добавьте @userinfobot в чат и отправьте любое сообщение
TEAM_CHAT_ID=-1001234567890

# Ваш Telegram ID (владелец)
# Узнать: напишите @userinfobot
OWNER_USER_ID=123456789

# ============================================================
# ДОСТУПЫ К СЕРВИСАМ (для автономной работы команды)
# ============================================================

# GitHub Personal Access Token (fine-grained)
# Создать: https://github.com/settings/personal-access-tokens/new
# Права: Contents (R/W), Workflows (R/W), Actions (R/W), Pull requests (R/W), Metadata (R)
GITHUB_TOKEN=
GITHUB_REPO=krivetka13011/fix-vpn

# Cloudflare API Token (Workers + D1 + KV + Pages)
# Создать: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# 3X-UI панель (VPN сервер)
XUI_PANEL_URL=
XUI_PANEL_USER=
XUI_PANEL_PASS=

# Supabase (база данных)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Vercel / Netlify (опционально)
# VERCEL_TOKEN=

# ============================================================
# LLM (GLM / Zhipu AI) — «мозги» ботов
# ============================================================
# Один ключ на всех ботов. Роли различаются system prompt'ами.
# Создать: https://open.bigmodel.cn/usercenter/apikeys
GLM_API_KEY=
GLM_MODEL=glm-4-flash
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
