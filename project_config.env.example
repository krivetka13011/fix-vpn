# Copy to project_config.env (gitignored) for local smoke checks + scripts.
# Never commit real tokens.

# E2E: same value must be set as Worker secret E2E_TRACE_SECRET (wrangler secret put)
E2E_TRACE_SECRET=change-me-to-random-secret

CLIENT_BOT_TOKEN=your_bot_token_from_BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_from_BotFather
WEBAPP_URL=https://app.fixvp.xyz

# Cloudflare D1 + KV (admin scripts: cleanup, provision, refresh caches)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=abd3a9f30b070ba7b27946ecb6b82945
D1_DATABASE_ID=de753b71-e8b6-4d60-8eab-2b10ce0ed098
KV_NAMESPACE_ID=1d9c845eb4c54a2d9db139b05104aaf3

# Optional: where smoke_check.py --notify sends reports (default: tester TG id)
SMOKE_NOTIFY_CHAT_ID=1159166497

XUI_BASE_URL=https://your-panel:54596/your-path
XUI_API_TOKEN=your_panel_api_token
SUBSCRIPTION_BASE_URL=https://fixvp.xyz:2096
SUBSCRIPTION_CLIENT_BASE_URL=https://sub.fixvp.xyz

# Happ Provider ID — https://happ-proxy.com (домен sub.fixvp.xyz привязан в кабинете)
HAPP_PROVIDER_ID=6Azh5Bya
SUBSCRIPTION_PATH=/sub

# Platega (https://docs.platega.io) — единственный способ оплаты в боте
# Callback URL в ЛК Platega: https://app.fixvp.xyz/api/webhook/platega
# MerchantId и API Secret: личный кабинет → Настройки
PLATEGA_MERCHANT_ID=your_merchant_uuid
PLATEGA_API_SECRET=your_api_secret_from_platega_dashboard

# QA test mode (Worker secrets TEST_MODE=1)
# TEST_MODE=1
# TRIAL_DURATION_MINUTES=2
# TEST_CHECKOUT_PRICE_RUB=1
# TEST_SUBSCRIPTION_MINUTES=10
